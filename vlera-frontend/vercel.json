{
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://vlhome.onrender.com/api/$1"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "https://vlhome.onrender.com/uploads/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
