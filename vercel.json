{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://vlhome.onrender.com/api/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://vlhome.onrender.com/uploads/$1"
    },
    {
      "source": "/",
      "destination": "/vlera-frontend/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/vlera-frontend/$1"
    }
  ]
}
